# ─────────────────────────────────────────────────────────────────────────────
# Steel Logistics & Dispatch Tracker – Environment Variables
# Copy this file to .env.local (never commit .env.local to git)
# ─────────────────────────────────────────────────────────────────────────────

# Supabase – get these from:
# Supabase Dashboard → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Mapbox token for GPS map views (leave blank to disable map)
VITE_MAPBOX_TOKEN=
